{
  "name": "@apitally/serverless",
  "version": "1.0.0",
  "description": "Simple API monitoring & analytics for REST APIs running on serverless platforms (e.g. Cloudflare Workers).",
  "author": "Apitally <hello@apitally.io>",
  "license": "MIT",
  "keywords": [
    "analytics",
    "api",
    "apitally",
    "cloudflare",
    "cloudflare-workers",
    "hono",
    "logging",
    "metrics",
    "middleware",
    "monitor",
    "monitoring",
    "plugin",
    "rest",
    "restful",
    "serverless",
    "workers"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/apitally/apitally-js-serverless.git"
  },
  "bugs": {
    "url": "https://github.com/apitally/apitally-js-serverless/issues"
  },
  "homepage": "https://apitally.io",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "format": "biome format --write .",
    "check": "tsc --noEmit && biome check .",
    "test": "vitest"
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    "./hono": {
      "types": "./dist/hono/index.d.ts",
      "import": "./dist/hono/index.js"
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "hono": "^4"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@hono/zod-validator": "^0.8.0",
    "@vitest/coverage-v8": "^4.0.0",
    "hono": "^4.6.5",
    "tsup": "^8.1.0",
    "typescript": "^6.0.3",
    "unplugin-swc": "^1.5.1",
    "vitest": "^4.0.0",
    "zod": "^3.23.8"
  }
}
